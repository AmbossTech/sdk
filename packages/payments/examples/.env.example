# Copy to `examples/.env` and fill in. `.env` is gitignored — never commit it.

# --- Required: API access -------------------------------------------------
# Scoped payments service key (sent as `x-api-key`). Starts with `amb_live...`.
AMBOSS_API_KEY=

# Optional: override the GraphQL endpoint (defaults to https://rails.amboss.tech/graphql).
# AMBOSS_BASE_URL=

# --- Optional: perform a real send ----------------------------------------
# Leave these unset to only run the read-only discovery (lists environments + wallets).
# Set WALLET_ID + TEAM_PASSWORD + one destination to actually send a payment.

# Wallet to send from.
# WALLET_ID=

# Team password — used ONLY to decrypt the node admin macaroon locally.
# It never leaves your process and is never sent to the API.
# TEAM_PASSWORD=

# Required when using a service API key with no `user` access (Argon2 salt).
# TEAM_ID=

# --- Destination (pick ONE) -----------------------------------------------
# A) BOLT11 invoice. Add AMOUNT_SATS only for zero-amount invoices.
# BOLT11=

# B) Lightning address — requires AMOUNT_SATS.
# LIGHTNING_ADDRESS=
# AMOUNT_SATS=

# --- Optional send tuning --------------------------------------------------
# FEE_LIMIT_SATS=10
# IDEMPOTENCY_KEY=
# TIMEOUT_SECONDS=60

# --- Receive (examples/receive.ts) ----------------------------------------
# Reuses WALLET_ID above. Leave WALLET_ID unset to just list wallets.
# Amount to invoice, in the wallet asset's base unit (sats for BTC). Default 1000.
# RECEIVE_AMOUNT_SATS=1000
# RECEIVE_DESCRIPTION=
