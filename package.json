{
  "name": "ambosstech-sdk",
  "private": true,
  "version": "0.0.0",
  "description": "Amboss TypeScript SDKs",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "typecheck": "pnpm --filter @ambosstech/core run build && pnpm -r --filter \"./packages/*\" run typecheck",
    "test": "pnpm --filter @ambosstech/core run build && pnpm -r --filter \"./packages/*\" run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -r --filter \"./packages/*\" run clean",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm -r --filter \"./packages/*\" run build && changeset publish"
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 2,
    "semi": true
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
